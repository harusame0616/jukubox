{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledMcpjsonServers": ["next-devtools"],
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "entire hooks claude-code post-task",
            "type": "command"
          }
        ],
        "matcher": "Task"
      },
      {
        "hooks": [
          {
            "command": "entire hooks claude-code post-todo",
            "type": "command"
          }
        ],
        "matcher": "TodoWrite"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/db-generate-context-injection.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "echo 'mcp__next-devtools__browser_eval は使用禁止です。playwright-cli を使用してください。' \u003e\u00262 \u0026\u0026 exit 2",
            "type": "command"
          }
        ],
        "matcher": "mcp__next-devtools__browser_eval"
      },
      {
        "hooks": [
          {
            "command": "entire hooks claude-code pre-task",
            "type": "command"
          }
        ],
        "matcher": "Task"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "entire hooks claude-code session-end",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "echo '## 参照可能な agent-docs ドキュメント一覧' && ls agent-docs/ | sed 's/^/- /'",
            "type": "command"
          },
          {
            "command": "entire hooks claude-code session-start",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "entire hooks claude-code stop",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "entire hooks claude-code user-prompt-submit",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "language": "japanese",
  "permissions": {
    "allow": [
      "Bash(git commit *)",
      "Bash(playwright-cli *)",
      "Skill(playwright-cli)"
    ],
    "ask": [],
    "deny": ["Read(./.entire/metadata/**)"]
  },
  "sandbox": {
    "autoAllowBashIfSandboxed": true,
    "enabled": true,
    "excludedCommands": ["gh:*", "git commit:*"],
    "filesystem": {
      "allowWrite": ["//tmp/pnpm/store"]
    },
