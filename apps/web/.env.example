# Supabase ローカル環境向け設定
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service Role キー（Mock 用 seed と medium テストで必要）
# `supabase status -o json | jq -r '.SERVICE_ROLE_KEY'` で取得
SUPABASE_SERVICE_ROLE_KEY=

# Mock 認証切替: `true` でパスワード認証、それ以外は実 OAuth
# 未指定時は実 OAuth
NEXT_PUBLIC_IS_MOCKED=true

# Mock 認証のログイン認証情報（NEXT_PUBLIC_IS_MOCKED=true のときのみ使用）
NEXT_PUBLIC_MOCK_AUTH_EMAIL=test@example.com
NEXT_PUBLIC_MOCK_AUTH_PASSWORD=password123

# API サーバー
API_URL=http://localhost:8080
